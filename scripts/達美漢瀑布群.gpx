9個關卡發配 8個關主+8個繩同
8組人員已在個關卡待命…
效率極高。
另外先鋒山路拓荒開路也很重要，
2-3位開路先鋒。</gpxhb:postscript><gpxhb:loadweight>10.0</gpxhb:loadweight><gpxhb:fitnesslevel>2</gpxhb:fitnesslevel><gpxhb:activitytype>others</gpxhb:activitytype><gpxhb:trackimageurl>https://assets.hikingbook.net/users/60w3wu1it91y2jmwdxciziq/tp2clbuiq1uw66uiar91rmg/ea1f8227-eef0-4e4f-9139-844490a0b79d.jpg</gpxhb:trackimageurl><gpxhb:device>Apple iPhone 13 Pro</gpxhb:device><gpxhb:source>Hikingbook</gpxhb:source></extensions></metadata><wpt lat="24.43599365653883" lon="121.74428156588388"><ele>117</ele><time>2025-06-20T21:48:52Z</time><name>00 Start</name><cmt>2025-06-21T05:48:52+08:00</cmt><desc>00 Start</desc><src>Hikingbook</src><link href="https://hikingbook.net/hikes/Tp2ClBuIQ1uW66uIar91rMg"><text>Hikingbook</text></link><extensions><gpxhb:weather>Clear</gpxhb:weather><gpxhb:speed>0.310000</gpxhb:speed><gpxhb:course>344.531250</gpxhb:course></extensions></wpt><wpt lat="24.436461292027303" lon="121.74362649461281"><ele>123</ele><time>2025-06-20T21:50:46Z</time><name>01 左切-入口</name><cmt>2025-06-21T05:50:46+08:00</cmt><desc>01 左切-入口</desc><src>Hikingbook</src><link href="https://hikingbook.net/hikes/Tp2ClBuIQ1uW66uIar91rMg"><text>Hikingbook</text></link><extensions><gpxhb:weather>Clear</gpxhb:weather><gpxhb:speed>0.000000</gpxhb:speed><gpxhb:course>285.213674</gpxhb:course></extensions></wpt><wpt lat="24.441086672513904" lon="121.7413363815511"><ele>210</ele><time>2025-06-20T22:18:20Z</time><name>02 上切點</name><cmt>2025-06-21T06:18:20+08:00</cmt><desc>02 上切點</desc><src>Hikingbook</src><link href="https://hikingbook.net/hikes/Tp2ClBuIQ1uW66uIar91rMg"><text>Hikingbook</text></link><extensions><gpxhb:weather>Clear</gpxhb:weather><gpxhb:speed>0.000000</gpxhb:speed><gpxhb:course>-1.000000</gpxhb:course></extensions></wpt><wpt lat="24.44175409763602" lon="121.74064378528033"><ele>232</ele><time>2025-06-20T22:41:01Z</time><name>03 上切（休息15分）</name><cmt>2025-06-21T06:41:01+08:00</cmt><desc>03 上切（休息15分）</desc><src>Hikingbook</src><link href="https://hikingbook.net/hikes/Tp2ClBuI